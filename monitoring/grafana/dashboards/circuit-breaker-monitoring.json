      }
    },
    {
      "id": 14,
      "title": "HTTP Circuit Breakers (Perplexity, Webhooks)",
      "description": "Circuit breaker states for external HTTP APIs",
      "type": "timeseries",
      "targets": [
        {
          "expr": "circuit_breaker_state{name=~\"http-.*\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CLOSED",
                  "color": "green"
                },
                "1": {
                  "text": "OPEN",
