                },
                "1": {
                  "text": "OPEN",
                  "color": "red"
                },
                "2": {
                  "text": "HALF_OPEN",
                  "color": "yellow"
                }
              }
            }
          ],
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      }
    },
    {
      "id": 13,
      "title": "Database Circuit Breakers",
      "description": "Circuit breaker states for database connection pools",
      "type": "timeseries",
      "targets": [
        {
          "expr": "circuit_breaker_state{name=~\"database-.*\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "CLOSED",
                  "color": "green"
                },
                "1": {
                  "text": "OPEN",
                  "color": "red"
                },
                "2": {
                  "text": "HALF_OPEN",
                  "color": "yellow"
                }
              }
            }
          ],
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
