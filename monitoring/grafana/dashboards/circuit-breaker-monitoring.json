      }
    },
    {
      "id": 15,
      "title": "Circuit Breaker Performance Impact",
      "description": "Comparison of requests with vs without circuit breaker protection",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(circuit_breaker_successes_total[5m]))",
          "legendFormat": "Protected Requests/sec",
          "refId": "A"
        },
        {
          "expr": "sum(rate(circuit_breaker_rejections_total[5m]))",
          "legendFormat": "Rejected Requests/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 52
      }
    },
    {
      "id": 16,
      "title": "Recent Circuit Breaker Events",
      "description": "Log of recent circuit breaker state transitions",
      "type": "logs",
      "targets": [
        {
          "expr": "{service=\"content-analysis-v2\"} |~ \"Circuit breaker.*transitioned\"",
          "refId": "A"
        },
        {
          "expr": "{service=\"feed-service\"} |~ \"Circuit breaker.*transitioned\"",
          "refId": "B"
        },
        {
          "expr": "{service=\"research-service\"} |~ \"Circuit breaker.*transitioned\"",
          "refId": "C"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 56
      }
    }
  ],
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m"
    ],
    "time_options": [
      "5m",
      "15m",
      "1h",
      "6h",
      "12h",
      "24h",
      "2d",
      "7d"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(circuit_breaker_state, name)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Circuit Opened",
        "datasource": "Prometheus",
        "expr": "changes(circuit_breaker_state{state=\"1\"}[1m])",
        "enable": true,
        "iconColor": "red",
        "tagKeys": "name"
      },
      {
        "name": "Circuit Closed",
        "datasource": "Prometheus",
        "expr": "changes(circuit_breaker_state{state=\"0\"}[1m])",
        "enable": true,
        "iconColor": "green",
        "tagKeys": "name"
      }
    ]
  },
  "version": 1
}
