```python
# tests/unit/test_my_template.py
import pytest
from app.templates.loader import template_loader

def test_my_template_loading():
    """Test my new template loads correctly."""
    template = template_loader.get_template("My Template Name")

    assert template is not None
    assert template.category == "my_category"
    assert len(template.parameters) > 0

def test_my_template_validation():
    """Test parameter validation."""
    template = template_loader.get_template("My Template Name")

    # Valid parameters
    is_valid, error = template.validate_parameters({
        "param1": "value1",
        "param2": 123
    })
    assert is_valid

    # Missing required parameter
    is_valid, error = template.validate_parameters({})
    assert not is_valid
    assert "Missing required parameter" in error
