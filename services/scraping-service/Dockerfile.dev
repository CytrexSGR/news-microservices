# Development Dockerfile for Scraping Service
# Fast rebuilds, hot-reload enabled, optimized for development workflow

FROM python:3.11-slim

WORKDIR /app

# System dependencies + Playwright browser dependencies
RUN apt-get update && apt-get install -y \
    curl \
    build-essential \
    gcc \
    g++ \
    # Playwright browser dependencies
    libglib2.0-0 \
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    libatspi2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy shared database package first (needed for imports)
COPY database/ database/

# Copy shared library
COPY libs/news-intelligence-common /tmp/news-intelligence-common

# Copy dependency files
COPY services/scraping-service/requirements.txt* services/scraping-service/requirements-dev.txt* ./

# Install dependencies (filter out editable install, install library separately)
RUN if [ -f "requirements.txt" ]; then \
        grep -v 'news-intelligence-common' requirements.txt > requirements-filtered.txt && \
        pip install --no-cache-dir /tmp/news-intelligence-common && \
        pip install --no-cache-dir -r requirements-filtered.txt; \
    fi

# Health check script

# Copy and setup health check script
COPY services/scraping-service/healthcheck.sh /usr/local/bin/healthcheck.sh
RUN chmod +x /usr/local/bin/healthcheck.sh

# Create non-root user
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

# Expose port

# Health check

# Development command with hot-reload
# Note: app/ directory will be mounted as volume, not copied

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8009", "--reload", "--log-level", "debug"]
