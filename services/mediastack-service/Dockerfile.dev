FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy shared library first
COPY libs/news-intelligence-common /tmp/news-intelligence-common

# Copy requirements first for better caching
COPY services/mediastack-service/requirements.txt .

# Install dependencies (filter out editable install, install library separately)
RUN grep -v 'news-intelligence-common' requirements.txt > requirements-filtered.txt && \
    pip install --no-cache-dir /tmp/news-intelligence-common && \
    pip install --no-cache-dir -r requirements-filtered.txt

# Copy application code
COPY app/ /app/app/
COPY tests/ /app/tests/

# Create non-root user
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

# Expose port
EXPOSE 8121

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8121/health || exit 1

# Run application with auto-reload
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8121", "--reload"]
