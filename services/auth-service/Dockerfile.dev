# Development Dockerfile for Auth Service
# Fast rebuilds, hot-reload enabled, optimized for development workflow

FROM python:3.11-slim

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y \
    curl \
    build-essential \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copy dependency files
COPY requirements.txt* pyproject.toml* poetry.lock* ./

# Install dependencies
# Try Poetry first, fallback to pip if no pyproject.toml
RUN if [ -f "pyproject.toml" ]; then \
        pip install --no-cache-dir poetry==1.7.0 && \
        poetry config virtualenvs.create false && \
        poetry install --no-interaction --no-ansi --no-root; \
    elif [ -f "requirements.txt" ]; then \
        pip install --no-cache-dir -r requirements.txt; \
    fi

# Copy and setup health check script
COPY healthcheck.sh /usr/local/bin/healthcheck.sh
RUN chmod +x /usr/local/bin/healthcheck.sh

# Create non-root user
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

# Expose port
EXPOSE 8000

# Enhanced health check - validates both imports and HTTP endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD /usr/local/bin/healthcheck.sh

# Development command with hot-reload
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--log-level", "debug"]
